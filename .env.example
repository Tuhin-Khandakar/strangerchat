# ============================================
# StrangerChat 2.0 - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database
DB_NAME=moderation.db

# Security
SESSION_SECRET=your_random_secret_key_here
ADMIN_PASSWORD=change_me_in_production

# CORS & Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Moderation
BANNED_WORDS=spam,scam,viagra,casino
PERSPECTIVE_API_KEY=

# Features
MAINTENANCE_MODE=false
TRUST_PROXY=false
ENABLE_ANALYTICS=false
LOG_LEVEL=debug

# Rate Limiting
CONN_RATE_LIMIT=15
MSG_RATE_LIMIT_MS=500

# Redis (Optional)
REDIS_URL=

# Stripe (Optional - for premium features)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Analytics & Monitoring (Optional)
SENTRY_DSN=
MIXPANEL_TOKEN=
POSTHOG_API_KEY=
GOOGLE_ANALYTICS_ID=

# Push Notifications (Optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
MAILTO_ADDRESS=your_email@example.com

# Performance
MAX_CONCURRENT_CONNECTIONS=10000
MATCH_TIMEOUT_MS=30000

# Feature Flags
ENABLE_VIDEO_CHAT=false
ENABLE_PREMIUM=false
ENABLE_REFERRALS=false
ENABLE_AI_MODERATION=false
